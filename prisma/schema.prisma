generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EstadoCliente {
  ACTIVO
  SUSPENDIDO
  CANCELADO
}

enum MetodoPago {
  MERCADOPAGO
  TRANSBANK
  TRANSFERENCIA
}

enum EstadoPago {
  PENDIENTE
  CONFIRMADO
  FALLIDO
}

enum TipoCobro {
  AUTOMATICO
  MANUAL
}

enum TipoAnuncio {
  INFO
  ADVERTENCIA
  EXITO
  MANTENIMIENTO
}

enum RolAdmin {
  ADMIN
  CONTADOR
}

model Vendedora {
  id          String    @id @default(cuid())
  nombre      String
  email       String?   @unique
  telefono    String?
  comisionPct Float?    @map("comision_pct") // null = usa el global de Configuracion
  activa      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  clientes    Cliente[]
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nombre    String
  rol       RolAdmin @default(ADMIN)
  createdAt DateTime @default(now())
}

model Plan {
  id               String        @id @default(cuid())
  clave            String        @unique
  nombre           String
  precio           Float
  intervalo        String        @default("mensual")
  maxProfesionales Int           @default(0) @map("max_profesionales")
  modulos          String[]      @default([])
  activo           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  clientes         Cliente[]
  suscripciones    Suscripcion[]
}

model Cliente {
  id             String        @id @default(cuid())
  nombre         String
  email          String        @unique
  telefono       String?
  dominio        String        @unique
  coolifyAppId   String?       @unique @map("coolify_app_id")
  serviceKey     String        @unique @default(cuid()) @map("service_key")
  apiUrl         String?       @map("api_url")
  planId         String?       @map("plan_id")
  plan           Plan?         @relation(fields: [planId], references: [id])
  rut            String?
  vendedoraId    String?       @map("vendedora_id")
  vendedora      Vendedora?    @relation(fields: [vendedoraId], references: [id])
  syncPending    Boolean       @default(false) @map("sync_pending")
  estado         EstadoCliente @default(ACTIVO)
  notas          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  suscripciones  Suscripcion[]
  magicLinks     MagicLink[]
  anuncios       Anuncio[]
  cotizaciones   Cotizacion[]
  facturas       Factura[]
  boletas        Boleta[]
}

model Anuncio {
  id        String      @id @default(cuid())
  titulo    String
  mensaje   String
  tipo      TipoAnuncio @default(INFO)
  // clienteId null = anuncio global (visible para todos los clientes)
  clienteId String?     @map("cliente_id")
  cliente   Cliente?    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  activo    Boolean     @default(true)
  fechaFin  DateTime?   @map("fecha_fin")
  createdAt DateTime    @default(now())
}

model MagicLink {
  id        String   @id @default(cuid())
  clienteId String   @map("cliente_id")
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usado     Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Suscripcion {
  id               String     @id @default(cuid())
  clienteId        String     @map("cliente_id")
  cliente          Cliente    @relation(fields: [clienteId], references: [id])
  monto            Float
  moneda           String     @default("CLP")
  metodoPago       MetodoPago @map("metodo_pago")
  tipoCobro        TipoCobro  @default(MANUAL) @map("tipo_cobro")
  planId           String?    @map("plan_id")
  plan             Plan?      @relation(fields: [planId], references: [id])
  mpSubscriptionId String?    @map("mp_subscription_id")
  mpPreapprovalId  String?    @map("mp_preapproval_id")
  tarjetaUlt4      String?    @map("tarjeta_ult4")
  fechaInicio      DateTime   @map("fecha_inicio")
  fechaVencimiento DateTime   @map("fecha_vencimiento")
  diasGracia       Int        @default(3) @map("dias_gracia")
  activa           Boolean    @default(true)
  createdAt        DateTime   @default(now())
  pagos            Pago[]
}

model Pago {
  id            String      @id @default(cuid())
  suscripcionId String      @map("suscripcion_id")
  suscripcion   Suscripcion @relation(fields: [suscripcionId], references: [id])
  monto         Float
  moneda        String      @default("CLP")
  estado        EstadoPago  @default(PENDIENTE)
  metodoPago    MetodoPago  @map("metodo_pago")
  referencia    String?
  notas         String?
  fechaPago     DateTime?   @map("fecha_pago")
  createdAt     DateTime    @default(now())
}

// ── Documentos comerciales ──────────────────────────────────────────────────

enum EstadoCotizacion {
  BORRADOR
  ENVIADA
  APROBADA
  RECHAZADA
  FACTURADA
  CONVERTIDA_BOLETA
}

enum EstadoFactura {
  PENDIENTE
  PAGADA
  VENCIDA
  ANULADA
}

enum EstadoBoleta {
  PENDIENTE
  PAGADA
  ANULADA
}

// Contador atómico para numeración correlativa
model DocumentoContador {
  id       String @id           // "cotizacion" | "factura" | "boleta"
  contador Int    @default(1)
}

model Cotizacion {
  id             String           @id @default(cuid())
  numero         String           @unique              // "COT-000001"
  clienteId      String?          @map("cliente_id")
  cliente        Cliente?         @relation(fields: [clienteId], references: [id])
  clienteNombre  String           @map("cliente_nombre")
  clienteRut     String           @default("") @map("cliente_rut")
  fecha          DateTime
  vigencia       String           @default("30 días")
  formaPago      String           @default("") @map("forma_pago")
  atte           String           @default("")
  comentarios    String           @default("")
  estado         EstadoCotizacion @default(BORRADOR)
  items          Json             @default("[]")
  subtotal       Float            @default(0)
  iva            Float            @default(0)
  total          Float            @default(0)
  deletedAt      DateTime?        @map("deleted_at")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  facturas       Factura[]
  boletas        Boleta[]
}

model Factura {
  id               String        @id @default(cuid())
  numero           String        @unique              // "FAC-000001"
  numeroSii        String        @default("") @map("numero_sii")
  clienteId        String?       @map("cliente_id")
  cliente          Cliente?      @relation(fields: [clienteId], references: [id])
  clienteNombre    String        @map("cliente_nombre")
  clienteRut       String        @default("") @map("cliente_rut")
  cotizacionId     String?       @map("cotizacion_id")
  cotizacion       Cotizacion?   @relation(fields: [cotizacionId], references: [id])
  fechaEmision     DateTime      @map("fecha_emision")
  fechaVencimiento DateTime      @map("fecha_vencimiento")
  plazoPago        String        @default("30") @map("plazo_pago")
  estado           EstadoFactura @default(PENDIENTE)
  montoNeto        Float         @default(0) @map("monto_neto")
  iva              Float         @default(0)
  total            Float         @default(0)
  items            Json          @default("[]")
  notas            String        @default("")
  adjuntos         Json          @default("[]")      // [{nombre, tipo, base64, fechaSubida}]
  deletedAt        DateTime?     @map("deleted_at")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Boleta {
  id            String        @id @default(cuid())
  numero        String        @unique              // "BOL-000001"
  numeroSii     String        @default("") @map("numero_sii")
  clienteId     String?       @map("cliente_id")
  cliente       Cliente?      @relation(fields: [clienteId], references: [id])
  clienteNombre String        @map("cliente_nombre")
  cotizacionId  String?       @map("cotizacion_id")
  cotizacion    Cotizacion?   @relation(fields: [cotizacionId], references: [id])
  fechaEmision  DateTime      @map("fecha_emision")
  estado        EstadoBoleta  @default(PENDIENTE)
  montoTotal    Float         @default(0) @map("monto_total")
  items         Json          @default("[]")
  notas         String        @default("")
  adjuntos      Json          @default("[]")
  deletedAt     DateTime?     @map("deleted_at")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// ── Configuración ────────────────────────────────────────────────────────────
// Configuración editable desde la UI (un solo registro "singleton").
model Configuracion {
  id               String  @id @default("config")
  empresaNombre    String  @default("") @map("empresa_nombre")
  empresaRut       String  @default("") @map("empresa_rut")
  empresaDireccion String  @default("") @map("empresa_direccion")
  soporteEmail     String  @default("") @map("soporte_email")
  soporteWhatsApp  String  @default("") @map("soporte_whatsapp")
  logoUrl          String  @default("") @map("logo_url")
  comisionPct      Float   @default(10) @map("comision_pct")
}

model LogSuspension {
  id           String   @id @default(cuid())
  clienteId    String   @map("cliente_id")
  accion       String
  motivo       String
  realizadoPor String   @map("realizado_por")
  createdAt    DateTime @default(now())
}
